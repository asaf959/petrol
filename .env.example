# Application
PORT=2018
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_password
DB_NAME=petrol_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=3h

# Admin Registration Secret
ADMIN_SECRET=iamadminlnb123

# API routes are under /api (e.g. /api/auth/login). Swagger: /docs
# Frontend always uses NEXT_PUBLIC_PETROL_API_URL=/api (local Next rewrite + production Nginx)
