# Application
PORT=2018
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_password
DB_NAME=petrol_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=3h

# Admin Registration Secret
ADMIN_SECRET=iamadminlnb123

# Production note: API routes are under /api (e.g. /api/auth/login)
# Swagger docs: /docs
# Frontend should set NEXT_PUBLIC_PETROL_API_URL=/api (Docker) or http://localhost:2018/api (local)
